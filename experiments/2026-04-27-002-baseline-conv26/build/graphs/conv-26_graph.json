    "5c0139c7-4335-4386-bd74-9bc10d554194": {
      "type": "Event",
      "canonical_name": "Melanie and Caroline chat",
      "aliases": [],
      "attrs": {
        "time": "2023-09-13",
        "conversation": "Caroline speak to Melanie at 12:09 am on 13 September, 2023: Whoa, Mel, that sign looks serious. Did anything happen? Melanie speak to Caroline at 12:09 am on 13 September, 2023: The sign was just a precaution, I had a great time. But thank you for your concern, you're so thoughtful! Caroline speak to Melanie at 12:09 am on 13 September, 2023: Phew! Glad it all worked out and you had a good time at the park! Melanie speak to Caroline at 12:09 am on 13 September, 2023: Yeah, it was so much fun! Those joyful moments definitely show us life's beauty."
      },
      "created_at": "2026-04-27 19:55:17",
      "updated_at": "2026-04-27 19:55:17"
    },
    "6f51ecc2-dba4-4f0e-b68d-846d2bb6cd28": {
